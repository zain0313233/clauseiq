# Copy these into clauseiq/.env (or set in your shell)

# Test user — must exist in your ClauseIQ database with docs uploaded
PLAYWRIGHT_TEST_EMAIL=you@example.com
PLAYWRIGHT_TEST_PASSWORD=your-password

# Optional overrides
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_ENGINE_URL=http://localhost:8000

# Set to 1 if Next.js is already running (skips webServer in playwright.config.ts)
# PLAYWRIGHT_SKIP_WEBSERVER=1

# Required when using PLAYWRIGHT_SKIP_WEBSERVER — disables API rate limits during E2E
# PLAYWRIGHT_TEST=1
